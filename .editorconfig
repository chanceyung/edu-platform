# EditorConfig — 统一代码风格 https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Java
[*.java]
indent_size = 4
max_line_length = 120

# 前端 JS/TS/Vue
[*.{js,ts,jsx,tsx,vue,json,html,css,scss,less}]
indent_size = 2
max_line_length = 120

# XML / YAML
[*.{xml,yml,yaml}]
indent_size = 2

# Markdown（保留尾部空格，换行用）
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# SQL
[*.sql]
indent_size = 2

# Makefile 必须用 tab
[Makefile]
indent_style = tab
